# Zoho-Parasut-Sync Environment Configuration
# Copy this file to .env and fill in your database credentials.
# NEVER commit .env to version control!

# Database
DB_HOST=localhost
DB_NAME=zoho_parasut_sync
DB_USER=root
DB_PASS=

# Optional: API credentials can also be set via the Settings panel in the browser
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_TLD=com

# PARASUT_CLIENT_ID=
# PARASUT_CLIENT_SECRET=
# PARASUT_USERNAME=
# PARASUT_PASSWORD=
# PARASUT_COMPANY_ID=

# Optional: Security
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# CRON_SECRET_KEY=
